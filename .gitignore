# ---------------------------------------------------------------------------
# Thư mục chứa thư viện (Dependencies) - Tuyệt đối không đẩy lên Git
# ---------------------------------------------------------------------------
node_modules/
**/node_modules/

# ---------------------------------------------------------------------------
# Bảo mật: Chặn tất cả các file .env ở mọi ngóc ngách (Gốc, Backend, Frontend)
# ---------------------------------------------------------------------------
**/.env
**/.env.local
*.local

# ---------------------------------------------------------------------------
# Thư mục sản phẩm sau khi build (Production Outputs)
# ---------------------------------------------------------------------------
dist/
dist-ssr/
**/dist/

# ---------------------------------------------------------------------------
# Nhật ký hệ thống và file lỗi (Logs)
# ---------------------------------------------------------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------------------------------------------------------
# Cấu hình riêng của các Editor/IDE (VS Code, WebStorm...)
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?